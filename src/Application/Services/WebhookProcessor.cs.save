git restore src/Application/Services/WebhookProcessor.cs 2>/dev/null || git checkout -- src/Application/Services/WebhookProcessor.cs




        };
    }

    // ── Map field name → friendly question ──────────────
    private static string FieldToQuestion(string field) => field switch
    {
        "items"         => "- Que productos deseas ordenar?",
        "delivery_type" => "- Es para *recoger* o *a domicilio*?",
        "notes"         => "- Alguna nota especial? (alergias, sin cebolla, etc.)",
        "date"          => "- Para que *fecha* seria? (ej. 2025-03-15)",
        "time"          => "- A que *hora*? (ej. 19:00)",
        "party_size"    => "- Para cuantas *personas*?",
        "name"          => "- A nombre de quien sera la reservacion?",
        _               => $"- Podrias proporcionarme: *{field}*?"
    };
}
