# WhatsApp Cloud API Configuration
# Copy this file to .env and fill in your values

WhatsApp__VerifyToken=your-custom-verify-token
WhatsApp__AccessToken=EAAGxxxxxxxxxx
WhatsApp__PhoneNumberId=123456789012345
WhatsApp__ApiVersion=v21.0
WhatsApp__AppSecret=your-app-secret-from-meta-dashboard
WhatsApp__RequireSignatureValidation=false

# OpenAI / AI Parser
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
AiParser__Model=gpt-4o-mini
AiParser__MaxTokens=512
AiParser__Temperature=0.1
AiParser__TimeoutSeconds=30

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8080
